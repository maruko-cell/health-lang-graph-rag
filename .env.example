# =============================================================================
# 后端环境变量模板（复制为 .env 后填写真实值，勿将 .env 提交到版本库）
# =============================================================================

# ---------- 基础 LLM ----------
DEFAULT_LLM=
OLLAMA_MODEL=
OLLAMA_BASE_URL=

# ---------- Neo4j（优先于此，未设置时从 backend/neo4j.yaml 读取）----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# 可选：指定 Neo4j 配置 YAML 路径，默认 backend/neo4j.yaml
# NEO4J_CONFIG_PATH=

# ---------- 前后端地址（CORS 与请求基地址）----------
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:4000

# ---------- 敏感词（可选，替换词用 | 分隔）----------
# SENSITIVE_WORDS=
# SENSITIVE_REPLACEMENT=

# ---------- 当前用户占位（未登录时使用；后续接登录后由 token 解析）----------
USER_ID=default_user
# USER_NAME=
# USER_SEX=
# USER_AGE=
# USER_HEIGHT=
# USER_WEIGHT=
# USER_BMI=
# USER_BMI_CATEGORY=

# ---------- Redis / 记忆 ----------
REDIS_URL=redis://localhost:6379/0
# SHORT_TERM_MEMORY_TTL=
# SHORT_TERM_MEMORY_MAX_TURNS=
# LONG_TERM_MEMORY_ENABLED=true
# PROFILE_UPDATE_ENABLED=true

# ---------- Chroma 向量库 ----------
